{
  // ==========================================================================
  // CURSOR SETTINGS TEMPLATE - Generated by CTOC
  // ==========================================================================
  // Comprehensive settings for Cursor IDE (VS Code-based with AI features).
  // Copy to .cursor/settings.json or use as workspace settings.
  // Last updated: 2024 - RED/BLUE TEAM REFINED (10 rounds)
  // ==========================================================================
  // Note: Cursor inherits VS Code settings - this template includes
  // Cursor-specific AI settings plus optimized VS Code base settings.
  // ==========================================================================

  // --------------------------------------------------------------------------
  // CURSOR AI SETTINGS
  // --------------------------------------------------------------------------

  // AI Model Configuration
  "cursor.ai.model": "claude-3.5-sonnet",
  "cursor.ai.fastModel": "gpt-4o-mini",
  "cursor.ai.slowModel": "claude-3.5-sonnet",

  // Chat Settings
  "cursor.chat.enabled": true,
  "cursor.chat.showInStatusBar": true,
  "cursor.chat.contextLength": "long",
  "cursor.chat.streamResponse": true,

  // Copilot++ (Tab Completion)
  "cursor.copilot++.enabled": true,
  "cursor.copilot++.suggestOnTriggerCharacters": true,
  "cursor.copilot++.acceptWithTab": true,
  "cursor.copilot++.displayStyle": "inline",
  "cursor.copilot++.enablePartialAccept": true,
  "cursor.copilot++.suppressSuggestionWhenTriggeredExplicitly": false,

  // Composer Settings
  "cursor.composer.enabled": true,
  "cursor.composer.autoSave": true,
  "cursor.composer.showDiff": true,

  // Context Settings
  "cursor.context.codebase": true,
  "cursor.context.symbols": true,
  "cursor.context.documentation": true,
  "cursor.context.gitHistory": true,
  "cursor.context.terminalOutput": true,

  // Privacy Settings
  "cursor.privacy.enableTelemetry": false,
  "cursor.privacy.codebaseIndexing": "local",

  // --------------------------------------------------------------------------
  // EDITOR CORE SETTINGS
  // --------------------------------------------------------------------------
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.trimAutoWhitespace": true,
  "editor.renderWhitespace": "selection",
  "editor.rulers": [80, 100, 120],
  "editor.wordWrap": "off",
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 120,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.indentation": true,
  "editor.stickyScroll.enabled": true,
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnEnter": "on",
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on"
  },
  "editor.parameterHints.enabled": true,
  "editor.semanticHighlighting.enabled": true,
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.unicodeHighlight.ambiguousCharacters": true,
  "editor.unicodeHighlight.invisibleCharacters": true,

  // --------------------------------------------------------------------------
  // CODE ACTIONS ON SAVE
  // --------------------------------------------------------------------------
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.organizeImports": "explicit",
    "source.addMissingImports": "explicit",
    "source.removeUnusedImports": "explicit"
  },

  // --------------------------------------------------------------------------
  // LANGUAGE-SPECIFIC FORMATTERS
  // --------------------------------------------------------------------------
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.tabSize": 2,
    "editor.autoIndent": "keep"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.tabSize": 4,
    "editor.insertSpaces": false,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.tabSize": 4,
    "editor.formatOnSave": true
  },
  "[java]": {
    "editor.defaultFormatter": "redhat.java",
    "editor.tabSize": 4
  },
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.tabSize": 4
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-docker",
    "editor.tabSize": 4
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "editor.tabSize": 2
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma",
    "editor.tabSize": 2
  },

  // --------------------------------------------------------------------------
  // TYPESCRIPT SETTINGS
  // --------------------------------------------------------------------------
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.quoteStyle": "single",
  "typescript.suggest.autoImports": true,
  "typescript.suggest.completeFunctionCalls": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": false,
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.suggest.autoImports": true,

  // --------------------------------------------------------------------------
  // ESLINT SETTINGS
  // --------------------------------------------------------------------------
  "eslint.enable": true,
  "eslint.format.enable": false,
  "eslint.lintTask.enable": true,
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "svelte"
  ],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "svelte"
  ],
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "eslint.useFlatConfig": true,

  // --------------------------------------------------------------------------
  // PRETTIER SETTINGS
  // --------------------------------------------------------------------------
  "prettier.enable": true,
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": true,

  // --------------------------------------------------------------------------
  // PYTHON SETTINGS
  // --------------------------------------------------------------------------
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.languageServer": "Pylance",
  "python.testing.pytestEnabled": true,
  "python.terminal.activateEnvironment": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // --------------------------------------------------------------------------
  // RUFF SETTINGS
  // --------------------------------------------------------------------------
  "ruff.enable": true,
  "ruff.organizeImports": true,
  "ruff.fixAll": true,

  // --------------------------------------------------------------------------
  // GO SETTINGS
  // --------------------------------------------------------------------------
  "go.useLanguageServer": true,
  "go.lintTool": "golangci-lint",
  "go.formatTool": "goimports",
  "gopls": {
    "ui.semanticTokens": true,
    "formatting.gofumpt": true
  },

  // --------------------------------------------------------------------------
  // RUST SETTINGS
  // --------------------------------------------------------------------------
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.inlayHints.chainingHints.enable": true,
  "rust-analyzer.inlayHints.parameterHints.enable": true,
  "rust-analyzer.inlayHints.typeHints.enable": true,

  // --------------------------------------------------------------------------
  // FILE ASSOCIATIONS
  // --------------------------------------------------------------------------
  "files.associations": {
    "*.env": "dotenv",
    "*.env.*": "dotenv",
    ".env.local": "dotenv",
    ".prettierrc": "json",
    ".eslintrc": "json",
    "*.mdx": "markdown",
    "Dockerfile*": "dockerfile"
  },

  // --------------------------------------------------------------------------
  // FILES: EXCLUDE
  // --------------------------------------------------------------------------
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.next": true,
    "**/.nuxt": true
  },

  // --------------------------------------------------------------------------
  // FILES: WATCHER EXCLUDE
  // --------------------------------------------------------------------------
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/target/**": true,
    "**/dist/**": true,
    "**/.next/**": true,
    "**/__pycache__/**": true
  },

  // --------------------------------------------------------------------------
  // SEARCH: EXCLUDE
  // --------------------------------------------------------------------------
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/coverage": true,
    "**/package-lock.json": true,
    "**/yarn.lock": true,
    "**/pnpm-lock.yaml": true,
    "**/.venv": true
  },
  "search.useIgnoreFiles": true,

  // --------------------------------------------------------------------------
  // TERMINAL SETTINGS
  // --------------------------------------------------------------------------
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.shellIntegration.enabled": true,

  // --------------------------------------------------------------------------
  // GIT SETTINGS
  // --------------------------------------------------------------------------
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.rebaseWhenSync": true,
  "git.inputValidation": true,
  "git.inputValidationSubjectLength": 72,

  // --------------------------------------------------------------------------
  // EMMET SETTINGS
  // --------------------------------------------------------------------------
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },
  "emmet.triggerExpansionOnTab": true,

  // --------------------------------------------------------------------------
  // EXPLORER SETTINGS
  // --------------------------------------------------------------------------
  "explorer.confirmDelete": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.sortOrder": "type",
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.d.ts, ${capture}.test.ts, ${capture}.spec.ts",
    "*.tsx": "${capture}.test.tsx, ${capture}.spec.tsx, ${capture}.stories.tsx",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, .npmrc",
    "tsconfig.json": "tsconfig.*.json, jsconfig.json",
    ".eslintrc.*": ".eslintignore, eslint.config.*",
    ".prettierrc*": ".prettierignore",
    "Cargo.toml": "Cargo.lock",
    "go.mod": "go.sum",
    "pyproject.toml": "poetry.lock, requirements*.txt, uv.lock",
    ".env": ".env.*, .env.local, .env.development, .env.production"
  },

  // --------------------------------------------------------------------------
  // WORKBENCH SETTINGS
  // --------------------------------------------------------------------------
  "workbench.editor.enablePreview": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.tree.indent": 16,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.startupEditor": "none",

  // --------------------------------------------------------------------------
  // DEBUG SETTINGS
  // --------------------------------------------------------------------------
  "debug.javascript.autoAttachFilter": "smart",
  "debug.openDebug": "openOnFirstSessionStart",

  // --------------------------------------------------------------------------
  // TESTING SETTINGS
  // --------------------------------------------------------------------------
  "testing.automaticallyOpenPeekView": "failureVisible",
  "testing.defaultGutterClickAction": "run",
  "testing.gutterEnabled": true,

  // --------------------------------------------------------------------------
  // SECURITY & TELEMETRY
  // --------------------------------------------------------------------------
  "security.workspace.trust.enabled": true,
  "telemetry.telemetryLevel": "off",

  // --------------------------------------------------------------------------
  // MISCELLANEOUS
  // --------------------------------------------------------------------------
  "breadcrumbs.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "problems.decorations.enabled": true,
  "window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${appName}"
}
